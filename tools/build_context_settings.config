[paths]
# Paths are resolved relative to this config file in /tools.
# Include app source, public game assets, and public framework config files.
scan_roots =
    ../src
    ../game-assets
    ../config

output_file = snapshots/codebase-context.txt

[options]
max_file_kb = 250
include_svg = false
include_lockfiles = false
tree_only = false