{
  "name": "nostos-framework",
  "productName": "Nostos Framework",
  "version": "0.0.23-prealpha",
  "description": "A forkable Electron and PixiJS framework for tabletop-style, RPG-inspired, and narrative games.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "validate:assets": "node scripts/validate-game-assets.mjs",
    "validate:config": "node scripts/validate-config.mjs",
    "prestart": "npm run validate:assets && npm run validate:config",
    "prepackage": "npm run check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm test && npm run validate:assets && npm run validate:config"
  },
  "keywords": [],
  "author": "eric",
  "license": "Apache-2.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "43.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "pixi.js": "^8.19.0"
  },
  "overrides": {
    "yauzl": "3.3.1"
  }
}
